<div class="bg-white p-6 rounded-2xl shadow">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-bold">Data Mahasiswa</h2>
    <a href="/mahasiswa/create" class="bg-blue-500 text-white px-4 py-2 rounded">+ Tambah</a>
  </div>

  <% if (success) { %>
    <div class="bg-green-100 text-green-700 p-3 rounded mb-4"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= error %></div>
  <% } %>

  <table class="w-full table-auto border-collapse">
    <thead>
      <tr class="bg-gray-100">
        <th class="border px-4 py-2 text-left">No</th>
        <th class="border px-4 py-2 text-left">Nama</th>
        <th class="border px-4 py-2 text-left">NIM</th>
        <th class="border px-4 py-2 text-left">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach((m, i) => { %>
        <tr class="hover:bg-gray-50">
          <td class="border px-4 py-2"><%= i + 1 %></td>
          <td class="border px-4 py-2"><%= m.nama %></td>
          <td class="border px-4 py-2"><%= m.nim %></td>
          <td class="border px-4 py-2 flex gap-2">
            <a href="/mahasiswa/edit/<%= m.id %>" class="bg-yellow-500 text-white px-3 py-1 rounded text-sm">Edit</a>
            <a href="/mahasiswa/delete/<%= m.id %>" class="bg-red-500 text-white px-3 py-1 rounded text-sm"
              onclick="return confirm('Yakin hapus data ini?')">Hapus</a>
          </td>
        </tr>
      <% }) %>
      <% if (mahasiswa.length === 0) { %>
        <tr>
          <td colspan="4" class="border px-4 py-2 text-center text-gray-400">Belum ada data</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
